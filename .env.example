# App
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
SSO_MASTER_KEY=""
# (Single-key mode) Set `SSO_MASTER_KEY` to a base64-encoded 32-byte key
# Optional envelope encryption mode (wraps a per-secret data key)
SSO_ENVELOPE_ENCRYPTION="false"
# Rotation defaults (optional)
# SSO_ROTATE_TARGET_KEY_ID="2025-02"
# SSO_ROTATE_FROM_KEY_ID="2024-12"
# SSO_ROTATE_DRY_RUN="true"
# Scheduled rotation hook (run via cron/task runner)
SSO_ROTATE_SCHEDULED="false"
SSO_ROTATE_MIN_INTERVAL_HOURS="0"

# Credentials provider (seeded admin)
ADMIN_EMAIL="admin@techhub.local"
# Leave ADMIN_PASSWORD empty to force the seed script to generate a
# one-time secure admin password and print it during initialization.
ADMIN_PASSWORD=""
ENABLE_CREDENTIALS="true"
ALLOW_SSO_EMAIL_LINKING="false"
TRUST_PROXY="false"
REQUIRE_PREPROVISIONED_USERS="true"

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Keycloak (optional fallback if not configured in UI)
KEYCLOAK_CLIENT_ID=""
KEYCLOAK_CLIENT_SECRET=""
KEYCLOAK_ISSUER=""

# Database
# Docker compose: use host `db`
# Local dev: use host `localhost`
# Optional explicit Postgres components (recommended for orchestrators)
# Use your secret store in production — do NOT commit credentials.
POSTGRES_USER="techhub"
POSTGRES_PASSWORD="techhub"
POSTGRES_DB="techhub"
POSTGRES_HOST="db"
POSTGRES_PORT="5432"
# WARNING: The default username/password `techhub/techhub` are for local
# development only. Change these values in production and supply them via
# your orchestrator's secret manager (Kubernetes secrets, Azure Key Vault,
# HashiCorp Vault, etc.). Running production with the default credentials
# is insecure and will be blocked by the runtime prestart checks.
# Example DATABASE_URL assembled from the values above:
DATABASE_URL="postgresql://techhub:techhub@db:5432/techhub?schema=public"

# Optional: storage backend for uploads. Set to `s3` to use S3, or leave empty for local filesystem.
# STORAGE_PROVIDER="s3"
# S3_BUCKET="your-bucket"
# S3_REGION="us-east-1"

# Optional: rate limiter store. Use `redis` to enable a Redis-backed limiter.
# NOTE: In production `RATE_LIMIT_STORE` MUST be set to "redis". Memory-based
# rate limiting is insecure and ineffective in multi-instance or serverless
# deployments — the application will fail fast when running in production if
# `RATE_LIMIT_STORE` is not "redis" to prevent accidental DoS/credential
# spraying amplification. For local development or isolated test runs you may
# set `RATE_LIMIT_STORE=memory`, but prefer Redis for any multi-process setup.
RATE_LIMIT_STORE="redis"
# Local dev: docker-compose will start a Redis container and the app will
# default to connecting to it via `REDIS_URL=redis://redis:6379` when using
# the provided compose file. In production you can point to an external Redis
# instance by setting `REDIS_URL` to your Redis connection string.
REDIS_URL="redis://redis:6379"
# Optional: provide a password or TLS flag if your Redis requires it.
# In production provide the password via your orchestrator/secret store,
# do not commit secrets into `.env`.
REDIS_PASSWORD=""
REDIS_TLS="false" # set to "true" to enable TLS (will pass TLS options to ioredis)
# Cache TTL (seconds) for user metadata (roles/mustChangePassword).
# If unset, defaults to 300 (5 minutes). When using Redis in production, tune
# this value to balance freshness vs. load.
USER_META_CACHE_TTL_SEC=300

# Reverse proxy / TLS (Nginx)
# The compose setup uses an `nginx` proxy configuration (`nginx/default.conf`).
# Nginx does not automatically provision ACME certificates. For TLS you can:
# - Mount certificates into the container and set `TLS_CERT_PATH`/`TLS_KEY_PATH`,
# - Run a separate certbot/ACME container to obtain certificates, or
# - Terminate TLS at a cloud load balancer and keep Nginx behind it.
# Leave DOMAIN empty for local development.
DOMAIN=""
TLS_CERT_PATH="" # path inside container to certificate (fullchain)
TLS_KEY_PATH=""  # path inside container to private key
PROXY_TYPE="nginx"
# If you want the compose proxy to generate a self-signed certificate for
# local testing, leave the TLS paths empty and the stack will create one at
# `./nginx/certs` on the host. To provide production certs, mount them into
# `./nginx/certs` or set `TLS_CERT_PATH`/`TLS_KEY_PATH` to the in-container paths.

# Test-mode guard
# For safety the codebase will not implicitly grant admin sessions in tests.
# If you need the legacy test fallback, set UNSAFE_TEST_AUTH=true in your
# test environment. Prefer using mocks or dependency injection instead.
UNSAFE_TEST_AUTH="false"
