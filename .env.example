# App
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
SSO_MASTER_KEY=""

# Credentials provider (seeded admin)
ADMIN_EMAIL="admin@techhub.local"
ADMIN_PASSWORD="ChangeMeNow!"
ENABLE_CREDENTIALS="true"
ALLOW_SSO_EMAIL_LINKING="false"
TRUST_PROXY="false"
REQUIRE_PREPROVISIONED_USERS="true"

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Keycloak (optional fallback if not configured in UI)
KEYCLOAK_CLIENT_ID=""
KEYCLOAK_CLIENT_SECRET=""
KEYCLOAK_ISSUER=""

# Database
# Docker compose: use host `db`
# Local dev: use host `localhost`
DATABASE_URL="postgresql://techhub:techhub@db:5432/techhub?schema=public"
