# App
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
SSO_MASTER_KEY=""
# (Single-key mode) Set `SSO_MASTER_KEY` to a base64-encoded 32-byte key
# Optional envelope encryption mode (wraps a per-secret data key)
SSO_ENVELOPE_ENCRYPTION="false"
# Rotation defaults (optional)
# SSO_ROTATE_TARGET_KEY_ID="2025-02"
# SSO_ROTATE_FROM_KEY_ID="2024-12"
# SSO_ROTATE_DRY_RUN="true"
# Scheduled rotation hook (run via cron/task runner)
SSO_ROTATE_SCHEDULED="false"
SSO_ROTATE_MIN_INTERVAL_HOURS="0"

# Credentials provider (seeded admin)
ADMIN_EMAIL="admin@techhub.local"
ADMIN_PASSWORD="ChangeMeNow!"
ENABLE_CREDENTIALS="true"
ALLOW_SSO_EMAIL_LINKING="false"
TRUST_PROXY="false"
REQUIRE_PREPROVISIONED_USERS="true"

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Keycloak (optional fallback if not configured in UI)
KEYCLOAK_CLIENT_ID=""
KEYCLOAK_CLIENT_SECRET=""
KEYCLOAK_ISSUER=""

# Database
# Docker compose: use host `db`
# Local dev: use host `localhost`
DATABASE_URL="postgresql://techhub:techhub@db:5432/techhub?schema=public"

# Optional: storage backend for uploads. Set to `s3` to use S3, or leave empty for local filesystem.
# STORAGE_PROVIDER="s3"
# S3_BUCKET="your-bucket"
# S3_REGION="us-east-1"

# Optional: rate limiter store. Use `redis` to enable a Redis-backed limiter.
# RATE_LIMIT_STORE="memory" # or "redis"
# REDIS_URL="redis://localhost:6379"
# Optional: cache TTL (seconds) for user metadata (roles/mustChangePassword).
# If unset, defaults to 300 (5 minutes). When using Redis in production, tune
# this value to balance freshness vs. load. If REDIS_URL is not set, the app
# falls back to an in-memory cache (single-process only).
# USER_META_CACHE_TTL_SEC=300
