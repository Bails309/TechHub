{
  "name": "techhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run prisma:push && next dev",
    "build": "next build",
    "start": "next start",
    "prestart": "node ./scripts/check-env.js",
    "lint": "eslint src --ext .ts,.tsx --no-error-on-unmatched-pattern",
    "prisma:generate": "prisma generate",
    "test": "vitest",
    "test:e2e": "playwright test",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push --accept-data-loss",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "esbuild": "$esbuild",
    "fast-xml-parser": "5.3.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1001.0",
    "@azure/storage-blob": "^12.26.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "ioredis": "^5.10.0",
    "ipaddr.js": "^2.2.0",
    "lucide-react": "^0.453.0",
    "next": "^15.1.0",
    "next-auth": "^4.24.7",
    "prisma": "^6.0.0",
    "rate-limiter-flexible": "^5.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.13.0",
    "tailwind-merge": "^2.6.1",
    "undici": "^6.23.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.12",
    "@playwright/test": "^1.49.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis-mock": "^8.2.6",
    "@types/node": "^20.19.35",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.1.0",
    "ioredis-mock": "^8.13.1",
    "postcss": "^8.5.8",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^1.6.1"
  }
}