# App
NEXTAUTH_SECRET="CkH5kcPpKPInQR5fkpfI1yQc7ZdIFd8MB0+jG7+NYos="
NEXTAUTH_URL="https://localhost"
NODE_ENV=development
SSO_MASTER_KEY="Dk170NH/ahjIE/dKzIpBhmhTQiEJFzgwx9JF22T5H68="

# Credentials provider (seeded admin)
ADMIN_EMAIL="admin@techhub.local"
# ADMIN_PASSWORD is intentionally left blank to force the seed script
# to generate a one-time secure password during initialization.
ADMIN_PASSWORD=""
REQUIRE_PREPROVISIONED_USERS="true"

# Session timeouts (OWASP baseline)
# Absolute max session lifetime in seconds (default: 28800 = 8 hours)
SESSION_MAX_AGE_SECONDS="28800"
# Idle timeout in milliseconds (default: 1200000 = 20 minutes)
SESSION_IDLE_TIMEOUT_MS="1200000"
NEXT_PUBLIC_SESSION_IDLE_TIMEOUT_MS="1200000"
# Idle timeout warning duration in milliseconds (default: 120000 = 2 minutes)
NEXT_PUBLIC_SESSION_WARNING_MS="120000"

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Database
# Docker compose: use host `db`
# Local dev: use host `localhost`
# Optional explicit Postgres components (recommended for orchestrators)
# Use your secret store in production — do NOT commit credentials.
POSTGRES_USER="techhub"
POSTGRES_PASSWORD="techhub"
POSTGRES_DB="techhub"
POSTGRES_HOST="db"
POSTGRES_PORT="5432"
# WARNING: The default username/password `techhub/techhub` are for local
# development only. Change these values in production and supply them via
# your orchestrator's secret manager (Kubernetes secrets, Azure Key Vault,
# HashiCorp Vault, etc.). Running production with the default credentials
# is insecure and will be blocked by the runtime prestart checks.
# Example DATABASE_URL assembled from the values above:
DATABASE_URL="postgresql://techhub:techhub@db:5432/techhub?schema=public"

# Redis (compose-provided local redis)
REDIS_URL="redis://redis:6379"
RATE_LIMIT_STORE="redis"
REDIS_PASSWORD=""
REDIS_TLS="false"

# Reverse proxy / TLS (Nginx)
# Set `DOMAIN` to your public domain for records and routing. When using
# the bundled `nginx` proxy you must provide TLS certificates (or run a
# separate ACME/certbot provisioning container). The compose scaffolding
# no longer manages automatic ACME for you.
DOMAIN=""
# If you have TLS certs mounted into the container, set the paths here.
TLS_CERT_PATH="" # e.g. /etc/ssl/certs/fullchain.pem
TLS_KEY_PATH=""  # e.g. /etc/ssl/private/privkey.pem
# Proxy engine selection (set to "nginx" by default)
PROXY_TYPE="nginx"

# Cache TTL
USER_META_CACHE_TTL_SEC=300

# Optional feature flags and provider placeholders
SSO_ENVELOPE_ENCRYPTION="false"
ENABLE_CREDENTIALS="true"
ALLOW_SSO_EMAIL_LINKING="false"
TRUST_PROXY="true"
TRUSTED_PROXIES=""

# Keycloak placeholders (optional)
KEYCLOAK_CLIENT_ID=""
KEYCLOAK_CLIENT_SECRET=""
KEYCLOAK_ISSUER=""

# Optional SSO rotation settings (leave commented or empty if not used)
#SSO_ROTATE_SCHEDULED="false"
#SSO_ROTATE_MIN_INTERVAL_HOURS="0"
